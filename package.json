{
  "name": "reportforge-ai",
  "version": "1.0.0",
  "private": true,
  "description": "Excel-native reporting add-in that turns selected ranges into workbook reports and companion client assets.",
  "license": "MIT",
  "config": {
    "app_to_debug": "excel",
    "app_type_to_debug": "desktop",
    "dev_server_port": 3000
  },
  "scripts": {
    "build": "webpack --mode production && npm run prerender:site",
    "build:dev": "webpack --mode development && npm run prerender:site",
    "build:test": "tsc --project tsconfig.test.json && node ./scripts/copy-test-vendors.mjs",
    "dev-server": "webpack serve --mode development",
    "lint": "office-addin-lint check",
    "lint:fix": "office-addin-lint fix",
    "prettier": "office-addin-lint prettier",
    "prerender:site": "node ./scripts/prerender-site.cjs",
    "site:assets": "powershell -ExecutionPolicy Bypass -File .\\scripts\\generate-store-assets.ps1",
    "google:validate-live": "node ./scripts/validate-google-live.mjs",
    "signin": "office-addin-dev-settings m365-account login",
    "signout": "office-addin-dev-settings m365-account logout",
    "start": "office-addin-debugging start manifest.xml",
    "stop": "office-addin-debugging stop manifest.xml",
    "test": "npm run build:test && node --test --test-isolation=none .test-dist/tests/dataProfiling.test.js .test-dist/tests/reportPlanning.test.js .test-dist/tests/reportBrief.test.js .test-dist/tests/storyPlanner.test.js .test-dist/tests/antiRepetition.test.js .test-dist/tests/chartHeuristics.test.js .test-dist/tests/reportingOutputQuality.test.js .test-dist/tests/siteContent.test.js .test-dist/tests/promptInterpretation.test.js .test-dist/tests/outputBundle.test.js .test-dist/tests/gasGenerator.test.js .test-dist/tests/slidesGenerator.test.js .test-dist/tests/slideTemplates.test.js .test-dist/tests/slideExports.test.js .test-dist/tests/templatePersistence.test.js .test-dist/tests/gmailDrafts.test.js .test-dist/tests/appsScriptProjects.test.js .test-dist/tests/llmEnhancement.test.js .test-dist/tests/llmHealth.test.js .test-dist/tests/llmClientAbort.test.js .test-dist/tests/agentPlanning.test.js .test-dist/tests/agentExecutionOffice.test.js .test-dist/tests/activateWorksheet.test.js .test-dist/tests/renderExcelReportHelpers.test.js .test-dist/tests/storageHardening.test.js .test-dist/tests/selectionGuardrails.test.js .test-dist/tests/googleAuthState.test.js .test-dist/tests/googleIdentity.test.js .test-dist/tests/googleApi.test.js .test-dist/tests/officeCapabilities.test.js .test-dist/tests/publicRuntimeConfig.test.js .test-dist/tests/reportingEngineRequest.test.js .test-dist/tests/reportingEngine.integration.test.js .test-dist/tests/reportingEngineDesign.test.js .test-dist/tests/reportingEngineHook.test.js .test-dist/tests/workflowFreshness.test.js .test-dist/tests/taskpaneNavigation.test.js .test-dist/tests/workspaceNavigation.test.js .test-dist/tests/taskpaneInteractivity.test.js .test-dist/tests/reportDraftState.test.js .test-dist/tests/activityHistory.test.js .test-dist/tests/diagnostics.test.js .test-dist/tests/singleFlight.test.js .test-dist/tests/formatting.test.js .test-dist/tests/reportScenarioMatrix.test.js .test-dist/tests/institutionalQualification.test.js .test-dist/tests/runtimeFeedback.test.js .test-dist/tests/userFeedback.test.js .test-dist/tests/canvasGeometry.test.js .test-dist/tests/canvasStudio.test.js .test-dist/tests/canvasHistory.test.js .test-dist/tests/canvasViewport.test.js",
    "typecheck": "tsc --project tsconfig.json",
    "validate": "office-addin-manifest validate manifest.xml",
    "validate:dist": "office-addin-manifest validate dist/manifest.xml",
    "version:check": "node ./scripts/check-version-sync.mjs",
    "watch": "webpack --mode development --watch"
  },
  "dependencies": {
    "core-js": "^3.36.0",
    "pdf-lib": "^1.17.1",
    "pptxgenjs": "^4.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "regenerator-runtime": "^0.14.1"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.25.4",
    "@babel/preset-react": "^7.24.7",
    "@babel/preset-typescript": "^7.23.3",
    "@types/node": "^24.5.2",
    "@types/office-js": "^1.0.377",
    "@types/office-runtime": "^1.0.35",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "babel-loader": "^9.1.3",
    "copy-webpack-plugin": "^12.0.2",
    "eslint-plugin-office-addins": "^4.0.3",
    "file-loader": "^6.2.0",
    "html-loader": "^5.0.0",
    "html-webpack-plugin": "^5.6.0",
    "office-addin-cli": "^2.0.3",
    "office-addin-debugging": "^6.0.3",
    "office-addin-dev-certs": "^2.0.3",
    "office-addin-lint": "^3.0.3",
    "office-addin-manifest": "^2.0.3",
    "office-addin-prettier-config": "^2.0.1",
    "os-browserify": "^0.3.0",
    "process": "^0.11.10",
    "source-map-loader": "^5.0.0",
    "typescript": "^5.4.2",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "5.1.0"
  },
  "prettier": "office-addin-prettier-config",
  "browserslist": [
    "last 2 Edge versions",
    "last 2 Chrome versions",
    "last 2 Firefox versions"
  ]
}
