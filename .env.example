# Public base URL used for production manifest rewrites.
REPORTFORGE_BASE_URL=https://addins.example.com/reportforge/

# Optional: sales inbox used by the marketing site launch request mailto action.
REPORTFORGE_SALES_EMAIL=

# Optional: marketing site endpoint used for real lead capture form submission.
# This can be an HTTPS webhook/CRM endpoint or a same-origin API route.
REPORTFORGE_SITE_LEAD_ENDPOINT=

# Optional: managed Google OAuth Web client ID for first-use sign-in.
# This must be a public Web client ID ending with .apps.googleusercontent.com.
# Do not place a Google API key (AIza...) here.
REPORTFORGE_GOOGLE_CLIENT_ID=

# Optional: force the in-addin Canvas Studio on or off.
# If omitted, the product now enables Canvas Studio by default.
REPORTFORGE_INTERNAL_REPORTING_ENGINE=true

# Optional: managed AI provider metadata. Keep real API keys out of this file.
REPORTFORGE_LLM_PROVIDER_LABEL=
REPORTFORGE_LLM_ENDPOINT=
REPORTFORGE_LLM_MODEL=
REPORTFORGE_LLM_API_KEY_HEADER=
REPORTFORGE_LLM_API_KEY_PREFIX=
REPORTFORGE_LLM_ORGANIZATION=

# Optional: server-side OpenAI key for the managed same-origin relay.
# Do not expose this key in the client bundle.
OPENAI_API_KEY=
